// events.json
// Формат:
// - Поля каждого события:
//     id (number)               — уникальный идентификатор
//     title (string)            — имя события
//     date (number|null)        — unix-время в секундах (например 1715668800), или null для TBA
//     desc (string, optional)   — краткое описание
// Пример: { "id": 1, "title": "Запуск", "desc": "Релиз", "date": 1715668800  }
[
    { "id": 1, "title": "Тест",  "desc": "Тест", "date": 1 },
    { "id": 6, "title": "Дота 2", "desc": ":3", "date": 1782259200}
]
